---
// BackToHub.astro
// Renders a persistent "Back to Society of Minds Aligned" button that links to the hub

interface Props {
  hubUrl?: string
  label?: string
}

const {
  hubUrl = 'https://agi2026.netlify.app',
  label = '← Back to Society of Minds Aligned'
} = Astro.props
---

<nav class="back-to-hub-nav">
  <a href={hubUrl} class="back-to-hub-link">
    {label}
  </a>
</nav>

<style>
  .back-to-hub-nav {
    padding: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    background: #03122b;
  }

  .back-to-hub-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #e9eaed;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  .back-to-hub-link:hover {
    color: #3c6cdd;
  }
</style>
