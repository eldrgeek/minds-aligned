</Base>

<style>
  h1 {
    font-size: var(--fontSize-hero, clamp(2rem, 5vw, 3.5rem));
    font-family: 'Cormorant Garamond', Georgia, serif;
    margin: 2rem 0 0.5rem;
    color: var(--color-text);
  }

  h2 {
    font-size: 1.75rem;
    font-family: 'Cormorant Garamond', Georgia, serif;
    margin: 2rem 0 1rem;
    color: var(--color-text);
  }

  section {
    margin: 2rem 0;
    padding: 1.5rem;
    border-left: 3px solid var(--color-accent);
  }

  p {
    margin: 0.5rem 0;
    color: var(--color-text-muted);
  }
</style>
