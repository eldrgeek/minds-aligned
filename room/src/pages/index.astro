---
import Base from '../layouts/Base.astro';
import data from '../data/exchanges.json';

const { pairs, questions, exchanges, meta } = data;
---

<Base title="The Room">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10 sm:py-14">
    <!-- Hero -->
    <header class="mb-10">
      <p class="font-mono text-xs uppercase tracking-eyebrow text-accent mb-3">Hero · v0 cached</p>
      <h1 class="font-display text-hero font-bold text-cream leading-tight mb-4">
        The Room
      </h1>
      <p class="text-muted text-lg max-w-2xl leading-relaxed">
        AI <em>representatives</em> of thinkers converse — every claim cited from the index.
        Pick a question and a pair; read the transcript; join when live mode ships.
      </p>
    </header>

    <!-- Disclaimer -->
    <aside
      id="disclaimer"
      class="mb-8 rounded-lg border border-accent/30 bg-accent/10 px-4 py-3 text-sm text-cream/90"
      role="note"
      aria-label="Representative disclaimer"
    >
      <p class="font-mono text-xs uppercase tracking-label text-accent mb-1">Disclaimer</p>
      <p>{meta.disclaimer} Use the hide toggles below to veto any representative you do not wish to see.</p>
    </aside>

    <!-- Controls -->
    <section class="grid gap-6 sm:grid-cols-2 mb-8" aria-label="Conversation selectors">
      <div>
        <label for="pair-select" class="block font-mono text-xs uppercase tracking-label text-muted mb-2">
          Pair
        </label>
        <select
          id="pair-select"
          class="w-full rounded-lg border border-border bg-navy-card text-cream px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-accent/50"
        >
          {pairs.map((p) => (
            <option value={p.id}>{p.label}</option>
          ))}
        </select>
      </div>
      <div>
        <label for="question-select" class="block font-mono text-xs uppercase tracking-label text-muted mb-2">
          Question
        </label>
        <select
          id="question-select"
          class="w-full rounded-lg border border-border bg-navy-card text-cream px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-accent/50"
        >
        </select>
      </div>
    </section>

    <!-- Representative visibility -->
    <section class="mb-8" aria-label="Representative visibility">
      <p class="font-mono text-xs uppercase tracking-label text-muted mb-3">Consent · hide representatives</p>
      <div id="rep-toggles" class="flex flex-wrap gap-3"></div>
    </section>

    <!-- Transcript -->
    <section aria-label="Conversation transcript">
      <div class="flex items-baseline justify-between gap-4 mb-4">
        <h2 id="exchange-title" class="font-display text-2xl text-cream font-semibold"></h2>
        <span id="exchange-meta" class="font-mono text-xs text-muted uppercase tracking-label shrink-0"></span>
      </div>
      <div
        id="transcript"
        class="rounded-xl border border-border bg-navy-card divide-y divide-border min-h-[12rem]"
        role="log"
        aria-live="polite"
      ></div>
    </section>

    <!-- Join -->
    <section class="mt-10" aria-label="Join the conversation">
      <p class="font-mono text-xs uppercase tracking-label text-muted mb-2">Join the room</p>
      <form id="join-form" class="flex flex-col sm:flex-row gap-3">
        <input
          id="join-input"
          type="text"
          placeholder="Pose a question to the panel…"
          class="flex-1 rounded-lg border border-border bg-navy-card text-cream px-4 py-3 text-sm placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-accent/50"
          autocomplete="off"
        />
        <button
          type="submit"
          class="rounded-lg bg-accent hover:bg-accent-hover text-cream font-medium px-6 py-3 text-sm transition-colors shrink-0"
        >
          Join
        </button>
      </form>
      <p id="join-notice" class="mt-3 text-sm text-muted hidden"></p>
    </section>

    <!-- TODO notice -->
    <p class="mt-8 text-xs font-mono text-muted/70 border-t border-border pt-6">
      TODO: live LLM mode (BYOK) · serve-time retrieval · voice
    </p>
  </div>

  <script define:vars={{ pairs, questions, exchanges }}>
    const STORAGE_KEY = 'room-hidden-reps';

    function loadHidden() {
      try {
        return new Set(JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'));
      } catch {
        return new Set();
      }
    }

    function saveHidden(hidden) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify([...hidden]));
    }

    let hiddenReps = loadHidden();

    const pairSelect = document.getElementById('pair-select');
    const questionSelect = document.getElementById('question-select');
    const repToggles = document.getElementById('rep-toggles');
    const transcript = document.getElementById('transcript');
    const exchangeTitle = document.getElementById('exchange-title');
    const exchangeMeta = document.getElementById('exchange-meta');
    const joinForm = document.getElementById('join-form');
    const joinInput = document.getElementById('join-input');
    const joinNotice = document.getElementById('join-notice');

    function getPair() {
      return pairs.find((p) => p.id === pairSelect.value);
    }

    function questionsForPair(pairId) {
      return questions.filter((q) => q.pairs.includes(pairId));
    }

    function populateQuestions() {
      const pairId = pairSelect.value;
      const qs = questionsForPair(pairId);
      questionSelect.innerHTML = qs
        .map((q) => `<option value="${q.id}">${q.text}</option>`)
        .join('');
    }

    function currentExchange() {
      const pairId = pairSelect.value;
      const questionId = questionSelect.value;
      return exchanges.find((e) => e.pairId === pairId && e.questionId === questionId);
    }

    function renderRepToggles() {
      const pair = getPair();
      if (!pair) return;
      repToggles.innerHTML = pair.thinkers
        .map((slug) => {
          const name = pair.names[slug];
          const glyph = pair.glyphs[slug];
          const checked = !hiddenReps.has(slug);
          return `
            <label class="inline-flex items-center gap-2 rounded-full border border-border bg-navy-card px-3 py-1.5 text-sm cursor-pointer hover:border-accent/40 transition-colors">
              <input type="checkbox" data-slug="${slug}" class="accent-accent rounded" ${checked ? 'checked' : ''} />
              <span class="font-mono text-xs text-accent">${glyph}</span>
              <span class="text-cream">${name}</span>
              <span class="font-mono text-[10px] uppercase tracking-label text-muted">rep</span>
            </label>
          `;
        })
        .join('');

      repToggles.querySelectorAll('input[type=checkbox]').forEach((cb) => {
        cb.addEventListener('change', () => {
          const slug = cb.dataset.slug;
          if (cb.checked) hiddenReps.delete(slug);
          else hiddenReps.add(slug);
          saveHidden(hiddenReps);
          renderTranscript();
        });
      });
    }

    function citationChip(cite) {
      const label = cite.source_type === 'tweet' ? 'post' : cite.source_type;
      const date = cite.date ? ` · ${cite.date}` : '';
      return `
        <a
          href="${cite.url}"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 mt-3 rounded-full border border-accent/40 bg-accent/10 px-3 py-1 text-xs font-mono text-accent hover:bg-accent/20 transition-colors"
          title="${cite.title}"
        >
          <span class="uppercase tracking-label">${label}</span>
          <span class="text-cream/80 truncate max-w-[14rem]">${cite.title}</span>
          <span class="text-muted">${date}</span>
          <span aria-hidden="true">↗</span>
        </a>
      `;
    }

    function renderTranscript() {
      const ex = currentExchange();
      const pair = getPair();
      if (!ex || !pair) {
        transcript.innerHTML = '<p class="p-6 text-muted text-sm">No exchange for this pair and question.</p>';
        return;
      }

      exchangeTitle.textContent = ex.question;
      exchangeMeta.textContent = pair.label;

      const visibleTurns = ex.turns.filter((t) => !hiddenReps.has(t.speaker));
      if (visibleTurns.length === 0) {
        transcript.innerHTML =
          '<p class="p-6 text-muted text-sm">All representatives hidden. Re-enable at least one to read the exchange.</p>';
        return;
      }

      transcript.innerHTML = visibleTurns
        .map((turn) => {
          const name = pair.names[turn.speaker];
          const glyph = pair.glyphs[turn.speaker];
          return `
            <article class="p-5 sm:p-6" data-speaker="${turn.speaker}">
              <header class="flex items-center gap-3 mb-2">
                <span class="flex h-9 w-9 items-center justify-center rounded-full bg-accent/20 font-mono text-xs text-accent border border-accent/30">${glyph}</span>
                <div>
                  <p class="font-medium text-cream">${name}</p>
                  <p class="font-mono text-[10px] uppercase tracking-label text-muted">AI representative · not ${name.split(' ')[0]}</p>
                </div>
              </header>
              <p class="text-body/95 leading-relaxed text-[15px]">${turn.text}</p>
              ${citationChip(turn.citation)}
            </article>
          `;
        })
        .join('');
    }

    pairSelect.addEventListener('change', () => {
      populateQuestions();
      renderRepToggles();
      renderTranscript();
    });

    questionSelect.addEventListener('change', renderTranscript);

    joinForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const q = joinInput.value.trim();
      if (!q) return;
      joinNotice.classList.remove('hidden');
      joinNotice.innerHTML =
        '<span class="text-accent font-mono text-xs uppercase tracking-label">v0 preset</span> — Live inference is not enabled yet (BYOK TODO). Try a seed question above, e.g. <em>Is agency substrate-independent?</em> or <em>What is a self?</em>';
      joinInput.value = '';
    });

    populateQuestions();
    renderRepToggles();
    renderTranscript();
  </script>
</Base>